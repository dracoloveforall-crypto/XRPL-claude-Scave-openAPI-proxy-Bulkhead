import cv2
import json
import hashlib
import datetime
from ultralytics import YOLO

# =====================================================
# SENSOR SYSTEM
# =====================================================

class SensorFusion:

    def __init__(self):

        self.sources = {
            "microscope": "microscope.jpg",
            "telescope": "telescope.jpg",
            "magnifier": "magnifier.jpg",
            "air_sampler": "air_sample.jpg"
        }

    def collect(self):

        images = []

        for source in self.sources.values():

            image = cv2.imread(source)

            if image is not None:
                images.append(image)

        return images


# =====================================================
# AI IMAGE ENHANCEMENT
# =====================================================

class QuantumZoomAI:

    def enhance(self, image):

        kernel = [
            [0,-1,0],
            [-1,5,-1],
            [0,-1,0]
        ]

        enhanced = cv2.filter2D(image,-1,kernel)

        return enhanced


# =====================================================
# MICROBE DETECTION
# =====================================================

class MicrobeDetector:

    def __init__(self):

        self.model = YOLO("microbe_model.pt")

    def detect(self, image):

        results = self.model.predict(
            source=image,
            conf=0.25
        )

        return results


