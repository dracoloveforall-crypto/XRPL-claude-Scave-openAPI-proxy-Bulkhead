    def calculate_entropy(self, data: bytes) -> float:
        """Measures Shannon Entropy to detect incoming or internal ransomware encryption attempts."""
        if not data:
            return 0.0
        entropy = 0.0
        length = len(data)
        frequencies = [0] * 256
        for byte in data:
            frequencies[byte] += 1
        for count in frequencies:
            if count > 0:
                p = count / length
                entropy -= p * math.log2(p)
        return entropy

