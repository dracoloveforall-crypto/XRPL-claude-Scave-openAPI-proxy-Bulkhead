import os
import requests
import base64

# Configuration
GITHUB_TOKEN = os.getenv("GITHUB_TOKEN")  # Securely loaded via environment variables
REPO_OWNER = "your_username"               # Replace with your GitHub username
REPO_NAME = "your_repository"             # Replace with your repository name
FILE_PATH = "Systemic_Vulnerabilities_and_Accountability_Report.cor"

def push_report_to_github(file_content, commit_message="Update vulnerabilities report"):
    """
    Pushes or updates the report file in the specified GitHub repository.
    """
    if not GITHUB_TOKEN:
        print("Error: GITHUB_TOKEN environment variable is not set.")
        return

    url = f"https://api.github.com/repos/{REPO_OWNER}/{REPO_NAME}/contents/{FILE_PATH}"
    headers = {
        "Authorization": f"token {GITHUB_TOKEN}",
        "Accept": "application/vnd.github.v3+json"
    }

    # Check if the file already exists to get its SHA (required for updates)
    get_response = requests.get(url, headers=headers)
    sha = None
    if get_response.status_code == 200:
        sha = get_response.json().get("sha")

    # Encode the content to Base64
    encoded_content = base64.b64encode(file_content.encode("utf-8")).decode("utf-8")

    # Prepare data payload
    data = {
        "message": commit_message,
        "content": encoded_content
    }
    if sha:
        data["sha"] = sha

    # Send PUT request to GitHub API
    put_response = requests.put(url, headers=headers, json=data)

    if put_response.status_code in [200, 201]:
        print(f"Success: {FILE_PATH} has been securely synchronized with GitHub.")
    else:
        print(f"Failed to push file: {put_response.status_code}")
        print(put_response.json())

# Example Usage
if __name__ == "__main__":
    # Replace this with the actual text content of your report
    report_data = "Initial setup framework for Systemic Vulnerabilities and Accountability Report."
    push_report_to_github(report_data)
